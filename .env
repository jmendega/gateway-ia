# ─────────────────────────────────────────────────────────────────────────────
# LiteLLM AI Gateway — Variables de entorno
# NTT DATA | Practice Digital & Innovation | Spike 2026
#
# INSTRUCCIONES:
#   1. Copiar este archivo: cp litellm/.env.example .env
#   2. Reemplazar los valores <PLACEHOLDER> con las credenciales reales
#   3. NUNCA commitear el archivo .env (está en .gitignore)
#
# API keys gratuitas (sin tarjeta de crédito):
#   Groq   → https://console.groq.com
#   Gemini → https://ai.google.dev
#   Ollama → https://ollama.ai (local, sin API key)
# ─────────────────────────────────────────────────────────────────────────────

# ── Proveedores de pago ────────────────────────────────────────────────────────
OPENAI_API_KEY=<TU_OPENAI_API_KEY>
ANTHROPIC_API_KEY=<TU_ANTHROPIC_API_KEY>

# ── Proveedores GRATUITOS ──────────────────────────────────────────────────────
# Groq — tier gratuito: 30 RPM, modelos open source ultra-rápidos
# Obtener en: https://console.groq.com → API Keys
GROQ_API_KEY=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

# Google Gemini — tier gratuito: 15 RPM, 1M tokens/día
# Obtener en: https://ai.google.dev → Get API key
GEMINI_API_KEY=AIzaSyAos1QYMfup5Un1kI201tg9ROcAuzOD6Uw

# Ollama — local, sin API key, sin internet
# Instalar: https://ollama.ai
# Descargar modelo: ollama pull llama3.2
# (No se requiere variable de entorno — se conecta via host.docker.internal:11434)

# ── LiteLLM — Autenticación ────────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-spike-nttdata-2026
LITELLM_SALT_KEY=00000000000000000000000000000032
UI_USERNAME=admin
UI_PASSWORD=admin123

# ── Base de datos (PostgreSQL) ─────────────────────────────────────────────────
DATABASE_URL=postgresql://litellm:litellm_password@postgres:5432/litellm

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password

# ── Presidio — Detección de PII ────────────────────────────────────────────────
PRESIDIO_ANALYZER_API_BASE=http://presidio-analyzer:3000
PRESIDIO_ANONYMIZER_API_BASE=http://presidio-anonymizer:3000
